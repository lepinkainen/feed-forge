<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title | xmlEscape}}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Georgia, "Times New Roman", serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; line-height: 1.55; }
        header { border-bottom: 2px solid #1a1a1a; padding-bottom: 0.75rem; margin-bottom: 1.5rem; }
        h1 { font-size: 1.8rem; }
        .date { color: #555; font-size: 0.95rem; margin-top: 0.25rem; }
        h2 { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; padding-bottom: 0.2rem; border-bottom: 1px solid #ddd; }
        p { margin-bottom: 0.9rem; }
        a { color: #0b5; text-decoration: none; }
        a:hover { text-decoration: underline; }
        sup a, p > a[href] { font-size: 0.85em; }
        footer { margin-top: 2.5rem; padding-top: 0.75rem; border-top: 1px solid #ddd; color: #888; font-size: 0.8rem; }
    </style>
</head>
<body>
    <header>
        <h1>{{.Slot | xmlEscape}} Bulletin</h1>
        <div class="date">{{.Date | xmlEscape}}</div>
    </header>
    <main>
{{.Content}}
    </main>
    <footer>Generated by feed-forge · {{.Generated | xmlEscape}}</footer>
</body>
</html>
